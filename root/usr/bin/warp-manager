#!/bin/sh
# Cloudflare WARP manager for OpenWrt using usque.
# SPDX-License-Identifier: GPL-3.0-or-later

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

CONFIG_DIR="/etc/warp"
ACCOUNT_FILE="$CONFIG_DIR/config.json"
UCI_CONFIG="/etc/config/warp"
USQUE_BIN="${USQUE_BIN:-/usr/bin/usque}"
CF_API="https://api.cloudflareclient.com/v0a2158"
REG_URL="$CF_API/reg"

info() {
	printf '%b\n' "${BLUE}$*${NC}"
}

ok() {
	printf '%b\n' "${GREEN}$*${NC}"
}

warn() {
	printf '%b\n' "${YELLOW}$*${NC}"
}

err() {
	printf '%b\n' "${RED}$*${NC}" >&2
}

need_usque() {
	if [ ! -x "$USQUE_BIN" ]; then
		err "usque was not found at $USQUE_BIN"
		err "Install usque first, or run the project install.sh on a supported architecture."
		return 1
	fi
}

need_jsonfilter() {
	if ! command -v jsonfilter >/dev/null 2>&1; then
		err "jsonfilter is required"
		return 1
	fi
}

need_curl() {
	if ! command -v curl >/dev/null 2>&1; then
		err "curl is required for this command"
		return 1
	fi
}

json_get() {
	jsonfilter -i "$ACCOUNT_FILE" -e "$1" 2>/dev/null
}

update_uci_account() {
	ADDRESS_V4="$(json_get '@.ipv4')"
	ADDRESS_V6="$(json_get '@.ipv6')"

	[ -f "$UCI_CONFIG" ] || touch "$UCI_CONFIG"
	uci -q get warp.config >/dev/null 2>&1 || uci set warp.config='warp'
	uci set warp.config.address_v4="${ADDRESS_V4:-}"
	uci set warp.config.address_v6="${ADDRESS_V6:-}"
	uci delete warp.config.private_key 2>/dev/null
	uci delete warp.config.public_key 2>/dev/null
	uci delete warp.config.reserved 2>/dev/null
	uci commit warp
}

register_account() {
	need_usque || return 1
	need_jsonfilter || return 1

	info "Registering a Cloudflare WARP account with usque..."
	mkdir -p "$CONFIG_DIR"

	backup_file=""
	if [ -s "$ACCOUNT_FILE" ]; then
		backup_file="$ACCOUNT_FILE.bak.$$"
		cp "$ACCOUNT_FILE" "$backup_file"
	fi

	rm -f "$ACCOUNT_FILE"
	if ! "$USQUE_BIN" -c "$ACCOUNT_FILE" register; then
		[ -n "$backup_file" ] && mv "$backup_file" "$ACCOUNT_FILE"
		err "registration failed"
		return 1
	fi

	if [ ! -s "$ACCOUNT_FILE" ]; then
		[ -n "$backup_file" ] && mv "$backup_file" "$ACCOUNT_FILE"
		err "registration did not create $ACCOUNT_FILE"
		return 1
	fi
	rm -f "$backup_file"

	ACCOUNT_ID="$(json_get '@.id')"
	[ -n "$ACCOUNT_ID" ] || {
		err "registration config is missing the account id"
		return 1
	}

	update_uci_account

	ok "registration succeeded"
	printf '%s\n' "Device ID: $ACCOUNT_ID"
	printf '%s\n' "IPv4: ${ADDRESS_V4:-not assigned}"
	printf '%s\n' "IPv6: ${ADDRESS_V6:-not assigned}"
}

apply_license() {
	LICENSE_KEY="$1"

	[ -n "$LICENSE_KEY" ] || {
		err "license key is required"
		return 1
	}
	[ -f "$ACCOUNT_FILE" ] || {
		err "no account config found; run 'warp-manager register' first"
		return 1
	}
	need_jsonfilter || return 1
	need_curl || return 1

	ACCOUNT_ID="$(json_get '@.id')"
	TOKEN="$(json_get '@.access_token')"
	[ -n "$ACCOUNT_ID" ] && [ -n "$TOKEN" ] || {
		err "account id or access token is missing from $ACCOUNT_FILE"
		return 1
	}

	info "Applying WARP+ license key..."
	RESPONSE="$(curl -s -X PUT "$REG_URL/$ACCOUNT_ID/account" \
		-H "Content-Type: application/json" \
		-H "Authorization: Bearer $TOKEN" \
		-d "{\"license\": \"$LICENSE_KEY\"}")"

	if printf '%s\n' "$RESPONSE" | grep -q '"license"'; then
		uci set warp.config.license_key="$LICENSE_KEY"
		uci commit warp
		ok "license key applied"
		return 0
	fi

	err "license update failed: $RESPONSE"
	return 1
}

detect_tun_iface() {
	if [ -s /var/run/warp/tun_iface ]; then
		cat /var/run/warp/tun_iface
		return
	fi

	ip link show 2>/dev/null | awk -F': ' '/^[0-9]+: tun[0-9]+/ {print $2; exit}'
}

get_status() {
	printf '%b\n' "${BLUE}=== WARP status ===${NC}"

	USQUE_INTERFACE="$(detect_tun_iface)"
	if pgrep -f "usque.*nativetun" >/dev/null 2>&1; then
		printf '%s\n' "Service: running"
		if [ -n "$USQUE_INTERFACE" ]; then
			printf '%s\n' "Interface: $USQUE_INTERFACE"
		else
			printf '%s\n' "Interface: waiting"
		fi
	else
		printf '%s\n' "Service: stopped"
	fi

	if [ -f "$ACCOUNT_FILE" ]; then
		need_jsonfilter || return 1
		ACCOUNT_ID="$(json_get '@.id')"
		ADDRESS_V4="$(json_get '@.ipv4')"
		ADDRESS_V6="$(json_get '@.ipv6')"

		printf '\n%b\n' "${BLUE}=== Account ===${NC}"
		printf '%s\n' "Device ID: ${ACCOUNT_ID:-not registered}"
		printf '%s\n' "IPv4: ${ADDRESS_V4:-none}"
		printf '%s\n' "IPv6: ${ADDRESS_V6:-none}"
	else
		printf '\n%b\n' "${YELLOW}No account config found. Run 'warp-manager register'.${NC}"
	fi

	printf '\n%b\n' "${BLUE}=== Proxy settings ===${NC}"
	GLOBAL_PROXY="$(uci -q get warp.config.global_proxy)"
	BYPASS_CHINA="$(uci -q get warp.config.bypass_china)"
	SOCKS_ENABLED="$(uci -q get warp.config.socks_enabled)"
	SOCKS_PORT="$(uci -q get warp.config.socks_port)"

	[ "$GLOBAL_PROXY" = "1" ] && printf '%s\n' "Global proxy: enabled" || printf '%s\n' "Global proxy: disabled"
	[ "$BYPASS_CHINA" = "1" ] && printf '%s\n' "China IP bypass: enabled" || printf '%s\n' "China IP bypass: disabled"
	[ "$SOCKS_ENABLED" = "1" ] && printf '%s\n' "SOCKS5: enabled on ${SOCKS_PORT:-1080}" || printf '%s\n' "SOCKS5: disabled"
}

test_connection() {
	info "Testing WARP connectivity..."
	need_curl || return 1

	USQUE_INTERFACE="$(detect_tun_iface)"
	if [ -z "$USQUE_INTERFACE" ]; then
		err "no usque TUN interface found"
		return 1
	fi

	TRACE="$(curl -s --interface "$USQUE_INTERFACE" --max-time 10 https://www.cloudflare.com/cdn-cgi/trace 2>/dev/null)"
	if [ -z "$TRACE" ]; then
		err "connection test failed"
		return 1
	fi

	WARP_STATUS="$(printf '%s\n' "$TRACE" | awk -F= '/^warp=/ {print $2}')"
	IP="$(printf '%s\n' "$TRACE" | awk -F= '/^ip=/ {print $2}')"
	LOC="$(printf '%s\n' "$TRACE" | awk -F= '/^loc=/ {print $2}')"

	ok "connection test succeeded"
	printf '%s\n' "WARP: ${WARP_STATUS:-unknown}"
	printf '%s\n' "IP: ${IP:-unknown}"
	printf '%s\n' "Location: ${LOC:-unknown}"
}

set_enabled() {
	value="$1"

	[ -f "$UCI_CONFIG" ] || touch "$UCI_CONFIG"
	uci -q get warp.config >/dev/null 2>&1 || uci set warp.config='warp'
	uci set warp.config.enabled="$value"
	uci commit warp
}

start_service() {
	set_enabled 1
	/etc/init.d/warp start
	ok "service start requested"
}

stop_service() {
	set_enabled 0
	/etc/init.d/warp stop
	ok "service stopped and disabled in UCI"
}

restart_service() {
	set_enabled 1
	/etc/init.d/warp restart
	ok "service restart requested"
}

reset_account() {
	warn "Removing WARP account config and stopping the service..."
	/etc/init.d/warp stop 2>/dev/null || true
	rm -f "$ACCOUNT_FILE"

	set_enabled 0
	uci delete warp.config.private_key 2>/dev/null
	uci delete warp.config.public_key 2>/dev/null
	uci delete warp.config.reserved 2>/dev/null
	uci set warp.config.address_v4=""
	uci set warp.config.address_v6=""
	uci set warp.config.license_key=""
	uci commit warp

	ok "account reset complete"
}

export_config() {
	[ -f "$ACCOUNT_FILE" ] || {
		err "no account config found"
		return 1
	}
	cat "$ACCOUNT_FILE"
}

usage() {
	cat <<EOF
Usage: $0 {register|license <key>|start|stop|restart|status|test|reset|export}

Commands:
  register       Register a new WARP account with usque
  license <key>  Apply a WARP+ license key
  start          Enable WARP in UCI and start the service
  stop           Stop the service and disable WARP in UCI
  restart        Enable WARP in UCI and restart the service
  status         Show service and account status
  test           Test WARP connectivity
  reset          Delete the local WARP account config
  export         Print the raw usque config
EOF
}

case "${1:-}" in
	register)
		register_account
		;;
	license)
		apply_license "${2:-}"
		;;
	start)
		start_service
		;;
	stop)
		stop_service
		;;
	restart)
		restart_service
		;;
	status)
		get_status
		;;
	test)
		test_connection
		;;
	reset)
		reset_account
		;;
	export)
		export_config
		;;
	*)
		usage
		exit 1
		;;
esac
